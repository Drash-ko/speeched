# Telegram Bot API token from @BotFather
BOT_TOKEN=replace-me

# Whisper / faster-whisper
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
DEFAULT_WHISPER_MODEL=medium
DEFAULT_RECOGNITION_LANGUAGE=auto
DEFAULT_UI_LANGUAGE=uk
WHISPER_CACHE_DIR=./whisper-cache
HF_HOME=./whisper-cache

# Local LLM post-processing
DEFAULT_LLM_MODEL=qwen2.5-3b
LLAMA_MODE=api
LLAMA_API_URL=http://127.0.0.1:8080

# SQLite
DATABASE_PATH=./data/bot.db

# Queue and cache
WORKER_COUNT=1
CACHE_TTL_SECONDS=3600

# Logging
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
LOG_RETENTION_DAYS=7
LOG_CLEANUP_INTERVAL_HOURS=24

# Retries
SQLITE_RETRY_COUNT=3
SQLITE_RETRY_BASE_DELAY=0.05
LLM_HTTP_RETRIES=3
LLM_HTTP_RETRY_DELAY=2.0
LLM_STARTUP_RETRIES=30
LLM_STARTUP_RETRY_DELAY=2.0
